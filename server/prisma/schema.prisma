generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int              @id @default(autoincrement())
  email       String           @unique
  password    String
  name        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  role        UserRole         @default(requester)
  feedbacks   Feedback[]
  submissions Submission[]
  preferences UserPreferences?

  @@map("users")
}

model UserPreferences {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  theme     String   @default("light")
  language  String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Submission {
  id              Int       @id @default(autoincrement())
  userId          Int
  question        String
  category        String?
  horoscope       String?
  gender          String?
  country         String?
  occupation      String?
  additionalNotes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reading         Reading?
  feedbacks       Feedback[]

  @@map("submissions")
}

model Reading {
  id                Int        @id @default(autoincrement())
  submissionId      Int        @unique
  astrologyReading  String?
  tarotReading      String?
  harmonisedReading String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  submission        Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  detectedCards     Card[]

  @@map("readings")
}

model Card {
  id          Int      @id @default(autoincrement())
  readingId   Int
  name        String
  position    String?
  orientation String?
  createdAt   DateTime @default(now())
  reading     Reading  @relation(fields: [readingId], references: [id], onDelete: Cascade)

  @@map("cards")
}

model Feedback {
  id           Int        @id @default(autoincrement())
  submissionId Int
  userId       Int
  rating       Int
  comment      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([submissionId, userId])
  @@map("feedbacks")
}

enum UserRole {
  requester
  admin
}
